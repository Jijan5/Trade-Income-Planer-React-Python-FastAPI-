# ===============================================
# 🔐 SECURITY CONFIGURATION
# ===============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control!

# =====================
# DATABASE (MySQL)
# =====================
MYSQL_USER=root
MYSQL_PASSWORD=your_secure_password
MYSQL_SERVER=localhost
MYSQL_PORT=your_sql_port
MYSQL_DB=your_db_name

# =====================
# JWT AUTHENTICATION
# =====================
SECRET_KEY=your_very_long_and_secure_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =====================
# CORS (Comma-separated)
# =====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =====================
# MIDTRANS PAYMENT GATEWAY
# =====================
# Sandbox (Development)
VITE_MIDTRANS_URL=https://app.sandbox.midtrans.com/snap/snap.js
VITE_MIDTRANS_CLIENT_KEY=your_sandbox_client_key

# Production (Uncomment for production)
# VITE_MIDTRANS_URL=https://app.midtrans.com/snap/snap.js
# VITE_MIDTRANS_CLIENT_KEY=your_production_client_key

# =====================
# EMAIL (SMTP)
# =====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# =====================
# GOOGLE AI (Optional)
# =====================
GOOGLE_API_KEY=your_google_api_key
